{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/layout/**",
              "components/work/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bricolage Grotesque|Hanken Grotesk|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Bricolage Grotesque, Hanken Grotesk, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|arrow|style|className|key|ref|className|style|children)$/]",
        "message": "<ArrowLink> doesn't accept that prop. Declared props: children, href, arrow, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='CaseSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|image|imageAlt|ratio|key|ref|className|style|children)$/]",
        "message": "<CaseSection> doesn't accept that prop. Declared props: label, children, image, imageAlt, ratio."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLinkItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<FooterLinkItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meta'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|children|style|className|key|ref|className|style|children)$/]",
        "message": "<Meta> doesn't accept that prop. Declared props: items, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLinkItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLinkItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|style|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, as, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:span|li|a|div)$/]",
        "message": "<Tag> as must be one of 'span' | 'li' | 'a' | 'div'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|meta|image|href|ratio|cta|key|ref|className|style|children)$/]",
        "message": "<WorkItem> doesn't accept that prop. Declared props: title, description, meta, image, href, ratio, cta."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "ArrowLink": {
        "replaces": []
      },
      "CaseSection": {
        "replaces": []
      },
      "FooterLinkItem": {
        "replaces": []
